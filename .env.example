# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.

# --- Supabase (browser-safe) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Server-only (NEVER expose to browser) ---
SUPABASE_SECRET_KEY=sb_secret_xxx

# --- Demo-only quick-login buttons ("Continue as Alice / Bob") ---
# Set to 1 in development to render the dev-login buttons on /login.
# OMIT or set to 0 in production builds — the Server Action also hard-blocks
# itself via NODE_ENV.
NEXT_PUBLIC_DEV_LOGIN=1

# --- Optional: configurable max amount in cents (default 100000000 = $1,000,000) ---
# PAYMENT_REQUEST_MAX_CENTS=100000000

# --- Used by Claude Code Supabase MCP server (.mcp.json) ---
# Personal Access Token: dashboard → Account → Access Tokens
SUPABASE_ACCESS_TOKEN=sbp_xxx
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
